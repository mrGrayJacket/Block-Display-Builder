$execute if score .collision bdb.settings matches ..0 at @e[type=ender_pearl,tag=summon.out] run summon block_display ~ ~ ~ {Tags:["bd","x$(layer_x)","y$(layer_y)","z$(layer_z)","not_air_block"],teleport_duration:$(teleport_duration),view_range:$(view_range)f,transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0.0f,0.0f,0.0f],scale:[$(scale_x)f,$(scale_y)f,$(scale_z)f]},block_state:{Name:"minecraft:blue_stained_glass"}}
$execute if score .collision bdb.settings matches 1.. at @e[type=ender_pearl,tag=summon.out] run summon block_display ~ ~ ~ {Tags:["bd","x$(layer_x)","y$(layer_y)","z$(layer_z)","not_air_block"],teleport_duration:$(teleport_duration),view_range:$(view_range)f,transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[$(translation_adjust_x)f,0.0f,$(translation_adjust_z)f],scale:[$(scale)f,$(scale)f,$(scale)f]},block_state:{Name:"minecraft:blue_stained_glass"}}
