$dialog show @s {type:"minecraft:multi_action",title:{text:"========================= Block Display Values =====================",color:"blue",bold:1b},"body":[{type:"minecraft:item",item:{id:"minecraft:grass_block"},description:{text:"One block = 1000",color:"gray"},show_tooltip:0b},{type:"minecraft:plain_message",contents:{text:"--------------------------------------",color:"gray"},"width":350}],inputs:[{type:"minecraft:text",key:"scale_bd_values",label:"Scale with collision (62 - 3000)",max_length:4,initial:"$(scale)"},{type:"minecraft:text",key:"scale_x_bd_values",label:"X Scale",max_length:5,initial:"$(scale_x)"},{type:"minecraft:text",key:"scale_y_bd_values",label:"Y Scale",max_length:5,initial:"$(scale_y)"},{type:"minecraft:text",key:"scale_z_bd_values",label:"Z Scale",max_length:5,initial:"$(scale_z)"},{type:"minecraft:number_range",key:"teleport_duration_bd_values",label:"Teleport duration",start:-1,end:59,step:1,initial:$(teleport_duration)},{type:"minecraft:number_range",key:"view_range_bd_values",label:"View range",start:1,end:200,step:1,initial:$(view_range)}],exit_action:{label:"Done",action:{type:"minecraft:show_dialog",dialog:"bdb:main_menu"}},actions:[{label:"Apply",action:{type:"minecraft:dynamic/run_command",template:"function bdb:dynamic_menus/bd_values/apply_bd_values {\"scale_bd_values\":$(scale_bd_values),\"scale_x_bd_values\":$(scale_x_bd_values),\"scale_y_bd_values\":$(scale_y_bd_values),\"scale_z_bd_values\":$(scale_z_bd_values),\"teleport_duration_bd_values\":$(teleport_duration_bd_values),\"view_range_bd_values\":$(view_range_bd_values)}"}},{label:"Reset",action:{type:"minecraft:run_command",command:"trigger bdb.menu set 3002"}}]}
